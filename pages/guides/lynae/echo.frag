<section class="guide-panel" data-page="echo">
  <header class="panel-header">
    <span class="eyebrow">Echo</span>
    <h2>Sets et priorites de stats</h2>
  </header>

  <div class="echo-shell">
    <div class="echo-sets">
      <article class="echo-set echo-set--best">
        <div class="echo-set__header">
          <div class="echo-set__title">
            <img src="../../assets/img/placeholders/guide-template/echo-icon.svg" alt="[Set 1]" />
            <div>
              <span class="echo-choice-label">Choix recommande</span>
              <h3>[Set 1]</h3>
              <p>
                Description du set principal a completer, avec
                <span class="accent-value">+XX% effet principal</span> et
                <span class="accent-value">+YY% effet secondaire</span> pour garder un volume de texte similaire.
              </p>
            </div>
          </div>
        </div>

        <div class="echo-item-grid">
          <article class="echo-item">
            <img src="../../assets/img/placeholders/guide-template/echo-icon.svg" alt="[Echo 1]" />
            <div>
              <span class="echo-item__label">Echo recommande</span>
              <h4>[Echo 1]</h4>
              <p>
                Explication de l'echo principal et de son usage en combat. Detaillez ici les interactions principales du build.
              </p>
            </div>
          </article>

          <article class="echo-item">
            <img src="../../assets/img/placeholders/guide-template/echo-icon.svg" alt="[Echo 2]" />
            <div>
              <span class="echo-item__label">Alternative utile</span>
              <h4>[Echo 2]</h4>
              <p>
                Variante plus situationnelle a decrire ici, avec un texte placeholder de longueur moyenne.
              </p>
            </div>
          </article>
        </div>
      </article>

      <article class="echo-set echo-set--alt">
        <div class="echo-set__header">
          <div class="echo-set__title">
            <img src="../../assets/img/placeholders/guide-template/echo-icon.svg" alt="[Set 2]" />
            <div>
              <span class="echo-choice-label">Alternative ciblee</span>
              <h3>[Set 2]</h3>
              <p>
                Description generique d'un second set a adapter selon les besoins du personnage et du mode de jeu.
              </p>
            </div>
          </div>
        </div>

        <div class="echo-item-grid">
          <article class="echo-item">
            <img src="../../assets/img/placeholders/guide-template/echo-icon.svg" alt="[Echo 3]" />
            <div>
              <span class="echo-item__label">Echo associe</span>
              <h4>[Echo 3]</h4>
              <p>
                Zone placeholder prevue pour un echo supplementaire. La structure peut accepter davantage de contenu si necessaire.
              </p>
            </div>
          </article>
        </div>
      </article>
    </div>

    <section class="echo-mainstats">
      <div class="echo-mainstats__header">
        <span class="echo-mainstats__kicker">Meilleures stats d'&Eacute;cho</span>
        <h3>Configuration 4 / 3 / 3 / 1 / 1</h3>
        <p>
          Commence par fixer les stats principales. Les substats viennent ensuite pour affiner le build.
        </p>
      </div>
      <div class="echo-mainstats__grid">
        <article class="mainstat-card">
          <span class="mainstat-card__slot">4 co&ucirc;t</span>
          <div class="mainstat-card__stats">
            <span class="mainstat-primary">[Main stat 4 co&ucirc;t]</span>
            <span class="mainstat-sep">&gt;</span>
            <span class="mainstat-alt">[Alternative]</span>
          </div>
        </article>
        <article class="mainstat-card mainstat-card--priority">
          <span class="mainstat-card__slot">3 co&ucirc;t</span>
          <div class="mainstat-card__stats">
            <span class="mainstat-primary">[Main stat 3 co&ucirc;t]</span>
          </div>
        </article>
        <article class="mainstat-card mainstat-card--priority">
          <span class="mainstat-card__slot">3 co&ucirc;t</span>
          <div class="mainstat-card__stats">
            <span class="mainstat-primary">[Main stat 3 co&ucirc;t]</span>
            <span class="mainstat-sep">&gt;</span>
            <span class="mainstat-alt">[Alternative]</span>
          </div>
        </article>
        <article class="mainstat-card">
          <span class="mainstat-card__slot">1 co&ucirc;t</span>
          <div class="mainstat-card__stats">
            <span class="mainstat-primary">[Main stat 1 co&ucirc;t]</span>
          </div>
        </article>
        <article class="mainstat-card">
          <span class="mainstat-card__slot">1 co&ucirc;t</span>
          <div class="mainstat-card__stats">
            <span class="mainstat-primary">[Main stat 1 co&ucirc;t]</span>
          </div>
        </article>
      </div>
      <div class="echo-substats-divider">
        <span>Substats prioritaires</span>
      </div>
      <div class="substats-grid substats-grid--single">
        <article class="substat-card">
          <h4>Ordre recommande</h4>
          <p>
            <span class="accent-text">[Stat 1]</span>
            &gt; <span class="accent-text">[Stat 2]</span>
            &gt;= <span class="accent-text">[Stat 3]</span>
            &gt; <span class="accent-text">[Stat 4]</span>
            &gt; <span class="accent-text">[Stat 5]</span>
            &gt; <span class="accent-text">[Stat 6]</span>
          </p>
        </article>
      </div>
    </section>
  </div>
</section>
