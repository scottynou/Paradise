<section class="guide-panel" data-page="echo">
  <header class="panel-header">
    <span class="eyebrow">Echo</span>
    <h2>Sets et priorités de stats</h2>
  </header>

  <div class="echo-shell">
    <div class="echo-sets">
      <article class="echo-set echo-set--best">
        <div class="echo-set__header">
          <div class="echo-set__title">
            <img src="../../assets/img/set/Rejuvenating%20Glow.png" alt="Éclat rajeunissant" />
            <div>
              <span class="echo-choice-label">Choix recommandé</span>
              <h3>Éclat rajeunissant</h3>
              <p>
                Le set le plus propre pour un usage support standard, avec
                <span class="accent-value">+10% bonus de soin</span> et
                <span class="accent-value">+15% ATQ d'équipe</span> après soin.
              </p>
            </div>
          </div>
        </div>

        <div class="echo-item-grid">
          <article class="echo-item">
            <img src="../../assets/img/echo/Fallacy%20of%20No%20Return.png" alt="X78 - Erreur intarissable" />
            <div>
              <span class="echo-item__label">Echo recommandé</span>
              <h4>X78 - Erreur intarissable</h4>
              <p>
                Le choix le plus stable pour soutenir la rotation avec de
                l'énergie, du buff et une excellente cohérence globale.
              </p>
            </div>
          </article>

          <article class="echo-item">
            <img src="../../assets/img/echo/Bell-Borne%20Geochelone.png" alt="Tortue clochante" />
            <div>
              <span class="echo-item__label">Alternative défensive</span>
              <h4>Tortue clochante</h4>
              <p>
                Une option plus sûre si vous voulez davantage de sécurité.
              </p>
            </div>
          </article>
        </div>
      </article>

      <article class="echo-set echo-set--alt">
        <div class="echo-set__header">
          <div class="echo-set__title">
            <img src="../../assets/img/set/Moonlit%20Clouds.png" alt="Nuages lunaires" />
            <div>
              <span class="echo-choice-label">Alternative ciblée</span>
              <h3>Nuages lunaires</h3>
              <p>
                Plus spécifique, mais très propre si vous cherchez surtout à
                renforcer un carry unique avec
                <span class="accent-value">+22,5% ATQ</span> après l'Outro.
              </p>
            </div>
          </div>
        </div>

        <div class="echo-item-grid">
          <article class="echo-item">
            <img src="../../assets/img/echo/Impermanence%20Heron.png" alt="Héron impermanent" />
            <div>
              <span class="echo-item__label">Echo associé</span>
              <h4>Héron impermanent</h4>
              <p>
                À privilégier si votre logique de team repose sur un swap propre
                vers un DPS principal qui profite directement du buff.
              </p>
            </div>
          </article>
        </div>
      </article>
    </div>

    <section class="echo-mainstats">
      <div class="echo-substats-divider">
        <span>Substats prioritaires</span>
      </div>

      <div class="substats-grid substats-grid--single">
        <article class="substat-card">
          <h4>Ordre recommandé</h4>
          <p>
            <span class="accent-text">Recharge d'énergie</span> (jusqu'à 130-140%)
            &gt; <span class="accent-text">DGT CRIT</span>
            &gt;= <span class="accent-text">DGT de Libération%</span>
            &gt; <span class="accent-text">PV%</span>
            &gt; <span class="accent-text">Taux CRIT</span>
            &gt; <span class="accent-text">PV</span>
            &gt; <span class="accent-text">ATQ%</span>
            = <span class="accent-text">ATQ</span>
          </p>
        </article>
      </div>
    </section>
  </div>
</section>
