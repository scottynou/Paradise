<section class="guide-panel endgame-page" data-page="stat-endgame">
  <header class="panel-header">
    <span class="eyebrow">Stats endgame</span>
    <h2>Repères à viser</h2>
    <p class="lede">
      La Recharge d'énergie reste la stat la plus importante,
      puis viennent les autres repères du build.
    </p>
  </header>

  <div class="endgame-strip endgame-strip--editorial">
    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">Recharge d'énergie</span>
        <span class="endgame-stat__hint">Priorité</span>
      </div>
      <strong class="endgame-stat__value">230%</strong>
      <p class="endgame-stat__note">Avant Echo / passif.</p>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">PV</span>
      </div>
      <strong class="endgame-stat__value">20 000 - 35 000+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">DEF</span>
      </div>
      <strong class="endgame-stat__value">1 100+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">Taux CRIT</span>
      </div>
      <strong class="endgame-stat__value">20 - 40%+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">DGT CRIT</span>
      </div>
      <strong class="endgame-stat__value">220 - 280%+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">Bonus DGT Spectro</span>
      </div>
      <strong class="endgame-stat__value">0 - 30%</strong>
    </article>
  </div>
</section>
