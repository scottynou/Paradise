<section class="guide-panel endgame-page" data-page="stat-endgame">
  <header class="panel-header">
    <span class="eyebrow">Stats finales</span>
    <h2>Rep&egrave;res &agrave; viser</h2>
    <p class="lede">
      La Recharge reste le vrai rep&egrave;re de confort, puis viennent les seuils CRIT et ATQ classiques.
    </p>
  </header>

  <div class="endgame-strip endgame-strip--editorial">
    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">Recharge d'énergie</span>
        <span class="endgame-stat__hint">Priorité</span>
      </div>
      <strong class="endgame-stat__value">116 - 125%</strong>
      <p class="endgame-stat__note">Plus bas avec Mortefi + Shorekeeper, plus haut avec Iuno + Shorekeeper.</p>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">PV</span>
      </div>
      <strong class="endgame-stat__value">14 500+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">DEF</span>
      </div>
      <strong class="endgame-stat__value">1 100+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">ATQ</span>
      </div>
      <strong class="endgame-stat__value">2 000 - 2 800+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">Taux CRIT</span>
      </div>
      <strong class="endgame-stat__value">65 - 80%+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">DGT CRIT</span>
      </div>
      <strong class="endgame-stat__value">210 - 260%+</strong>
    </article>

    <article class="endgame-stat">
      <div class="endgame-stat__head">
        <span class="endgame-stat__label">Bonus DGT Electro</span>
      </div>
      <strong class="endgame-stat__value">40 - 70%+</strong>
    </article>
  </div>
</section>
